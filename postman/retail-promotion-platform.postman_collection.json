{
  "info": {
    "name": "Retail Promotion Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "http://localhost:8080/api/v1/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"jane.doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"SecurePass123\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "http://localhost:8080/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"jane.doe\",\n  \"password\": \"SecurePass123\"\n}"
        }
      }
    },
    {
      "name": "Promotion - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "http://localhost:8080/api/v1/promotions/commands",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Summer Sale 25%\",\n  \"description\": \"25% off summer collection\",\n  \"type\": \"PERCENTAGE_DISCOUNT\",\n  \"discountValue\": 25,\n  \"zoneCode\": \"UK-SOUTH\",\n  \"startDate\": \"2026-07-01T00:00:00Z\",\n  \"endDate\": \"2026-08-01T00:00:00Z\"\n}"
        }
      }
    },
    {
      "name": "Promotion - Get By Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "http://localhost:8080/api/v1/promotions/{{promotionId}}"
      }
    }
  ]
}